{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vc-radar",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "vc-radar-db",
      "database_id": "local",
      "migrations_dir": "migrations"
    }
  ],
  "triggers": {
    "crons": ["0 */6 * * *"]
  }
}
